#!/usr/bin/env bash
# =============================================================================
#  config.env — Proxmox AI Stack Global Configuration
#
#  Single source of truth for all settings across every script in this repo.
#  All scripts source this file via:
#    source "$(dirname "$0")/config.env"
#
#  USAGE
#  ─────
#  1. Edit the values below to match your environment.
#  2. Run  bash init_secrets.sh  ONCE to populate the Secrets section.
#  3. Never run any other script before completing steps 1 and 2.
#
#  RULES
#  ─────
#  - Do NOT use $(command) substitutions in this file. They re-execute on
#    every source, which causes values like passwords to regenerate each run.
#  - Keep secrets as static strings. Use init_secrets.sh to generate them.
#  - This file is sourced — it must not call exit or produce output.
# =============================================================================


# =============================================================================
#  NETWORK
#  ───────
#  Applies to all VMs. Must match your LAN topology.
#  Verify your Proxmox bridge name with:  ip link show
# =============================================================================

# Proxmox virtual bridge shared by all VMs and LXC containers.
BRIDGE="vmbr0"

# Default gateway (your router). VMs route all non-local traffic here.
GATEWAY="10.0.3.1"

# DNS resolver injected into each VM via cloud-init.
NAMESERVER="1.1.1.1"

# CIDR prefix length for all VM static IPs (24 = /24 = 255.255.255.0).
SUBNET_MASK="24"


# =============================================================================
#  VM STATIC IP ADDRESSES
#  ──────────────────────
#  Assign five free IPs from your LAN that are:
#    - Outside your router's DHCP pool
#    - Reachable from the Proxmox host
#    - Reachable from each other (same subnet or routed)
# =============================================================================

# ai-vm: Ollama, Open WebUI, AnythingLLM, Qdrant, Whisper, Nginx.
AI_VM_IP="10.0.3.10"

# coding-vm: OpenCode and Continue (connects to Ollama on ai-vm).
CODING_VM_IP="10.0.3.20"

# data-vm: PostgreSQL 16 + pgvector. Shared database server for all VMs.
DATA_VM_IP="10.0.3.30"

# automation-vm: n8n and Flowise. Both backed by Postgres on data-vm.
AUTOMATION_VM_IP="10.0.3.40"

# monitoring-vm: Prometheus and Grafana. Scrapes metrics from all VMs.
MONITORING_VM_IP="10.0.3.50"


# =============================================================================
#  VM IDs (VMID)
#  ─────────────
#  Proxmox-unique integer identifiers for each VM.
#  Must not conflict with existing VMs or containers.
#  Verify current usage with:  qm list && pct list
#  LXC containers (deploy_lxc_stack.sh) use the range 400–499.
# =============================================================================

AI_VM_ID=200
CODING_VM_ID=201
DATA_VM_ID=202
AUTOMATION_VM_ID=203
MONITORING_VM_ID=204

# Template VM — created by create_template.sh; cloned by 01_create_vms.sh when USE_TEMPLATE=1.
# Must not conflict with VMs (200-204) or LXC containers (400+).
TEMPLATE_VMID=199


# =============================================================================
#  VM RESOURCES
#  ────────────
#  RAM in MB, Disk in GB.
# =============================================================================

# ai-vm: GPU inference + 5 Docker services + Nginx.
# The RTX 4090 offloads inference but Ollama still needs RAM for model loading.
AI_VM_RAM=32768        # 32 GB
AI_VM_CORES=12
AI_VM_DISK=120         # GB — Ollama model storage lives in a Docker volume here

# coding-vm: No persistent services; just config files and CLI tooling.
CODING_VM_RAM=8192     # 8 GB
CODING_VM_CORES=4
CODING_VM_DISK=60

# data-vm: Postgres shared_buffers is tuned to ~25% of this RAM value (4 GB).
DATA_VM_RAM=16384      # 16 GB
DATA_VM_CORES=4
DATA_VM_DISK=150       # GB — allocate generously; pgvector indices can be large

# automation-vm: n8n and Flowise; RAM spikes during parallel workflow execution.
AUTOMATION_VM_RAM=8192 # 8 GB
AUTOMATION_VM_CORES=4
AUTOMATION_VM_DISK=60

# monitoring-vm: Prometheus TSDB retention is 30 days; size disk accordingly.
MONITORING_VM_RAM=4096 # 4 GB
MONITORING_VM_CORES=2
MONITORING_VM_DISK=40


# =============================================================================
#  STORAGE
#  ───────
#  Proxmox storage pool where VM disks and cloud images are written.
#  List available pools with:  pvesm list
#  Common values: local-lvm, local-zfs, ceph-pool
# =============================================================================

STORAGE="local-lvm"


# =============================================================================
#  UBUNTU CLOUD IMAGE
#  ──────────────────
#  Used by 01_create_vms.sh to provision all VMs from a single base image.
#  The image is downloaded once to CLOUD_IMAGE_PATH and reused for all VMs.
#
#  To switch Ubuntu versions change both URL and NAME:
#    22.04 (Jammy): jammy-server-cloudimg-amd64.img  /  cloud-images.ubuntu.com/jammy/...
#    24.04 (Noble): noble-server-cloudimg-amd64.img  /  cloud-images.ubuntu.com/noble/...
# =============================================================================

CLOUD_IMAGE_URL="https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img"
CLOUD_IMAGE_NAME="noble-server-cloudimg-amd64.img"
CLOUD_IMAGE_PATH="/var/lib/vz/template/iso/${CLOUD_IMAGE_NAME}"


# =============================================================================
#  SSH ACCESS
#  ──────────
#  The public key injected into every VM via cloud-init.
#  Generate:  ssh-keygen -t ed25519 -C "proxmox-ai"
#  Print:     cat ~/.ssh/id_ed25519.pub
# =============================================================================

SSH_PUBLIC_KEY="ssh-ed25519 AAAAC3NzaC1... your-key-here"


# =============================================================================
#  VM DEFAULT USER
#  ───────────────
#  Cloud-init creates this user on every VM.
#  VM_PASSWORD is only for emergency console access — SSH key auth is primary.
# =============================================================================

VM_USER="ubuntu"
VM_PASSWORD="ChangeMe123!"   # change this; used only as console fallback


# =============================================================================
#  DOMAIN
#  ──────
#  Used by Nginx (ai-vm) for server_name directives.
#  Use your real domain for external access, or "ai.local" for LAN-only.
# =============================================================================

BASE_DOMAIN="ai.local"


# =============================================================================
#  SECRETS
#  ───────
#  Leave these as empty strings "" below.
#  Run  bash init_secrets.sh  ONCE to generate and write static values here.
#
#  WHY EMPTY: Assigning secrets as $(openssl rand ...) re-runs the command
#  on every source call, generating a new value each time. This causes the
#  Postgres password used when creating the server to differ from the one
#  used when connecting — breaking all services silently.
# =============================================================================

# PostgreSQL superuser password. Used by all services connecting to data-vm.
POSTGRES_PASSWORD=""

# AnythingLLM JWT signing key. Changing this invalidates all active sessions.
ANYTHINGLLM_JWT_SECRET=""

# n8n credential encryption key. Changing this permanently destroys all saved
# credentials in n8n. Store a backup copy in a password manager.
N8N_ENCRYPTION_KEY=""

# Grafana admin password. Change via UI after first login.
GRAFANA_ADMIN_PASSWORD="admin"
